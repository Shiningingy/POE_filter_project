    Class "Life Flasks" "Mana Flasks" "Utility Flasks"
    Quality >= 15
    AreaLevel <= 68
    SetFontSize 42
    SetTextColor 255 255 255 255
    SetBorderColor 160 160 165 255
    SetBackgroundColor 32 32 33 255
    PlayAlertSound 1 300
    PlayEffect Grey
    MinimapIcon 1 Grey Diamond


