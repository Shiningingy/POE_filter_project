# 在此添加自定义规则将会覆盖所有过滤器设定.


#===================================================================================================================
# [[10000]] 过渡 _campaign
#===================================================================================================================

#==[11000]-过渡 _campaign - 武器过渡 Weapon Progression==

#==[12000]-过渡 _campaign - 防具过渡 Armour Progression==

#==[12001]- 防具 -隐秘传奇 防具过渡 - Class Condition==
Show
    Rarity Unique
    Identified True
    HasExplicitMod "Veil"
    AreaLevel <= 67
    ItemLevel <= 72
    SetFontSize 40
    SetBorderColor 74 230 58 255
    SetBackgroundColor 215 215 200 210
    PlayAlertSound 2 300


#==[12002]- 防具 -移速鞋 25%+ 防具过渡 - Class Condition==
Show
    Class == "Boots"
    Rarity Magic Rare
    Identified True
    HasExplicitMod "Gazelle's" "Cheetah's" "Hellion's"
    AreaLevel <= 67
    ItemLevel <= 72
    SetFontSize 40
    SetBorderColor 74 230 58 255
    SetBackgroundColor 215 215 200 210
    PlayAlertSound 2 300


#==[12003]- 防具 -移速鞋 20%（至第三章） 防具过渡 - Class Condition==
Show
    Class == "Boots"
    Rarity Magic Rare
    Identified True
    HasExplicitMod "Stallion's"
    AreaLevel <= 33
    ItemLevel <= 38
    SetFontSize 35
    SetBorderColor 74 230 58 255
    PlayAlertSound 2 300


