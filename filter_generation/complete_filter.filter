#==[128000]-过渡 _campaign - 过渡护甲 Campaign Armour==

#==[128001]- Campaign Armour -4-Link (Campaign) 过渡护甲 - Class Condition==
Show
    Class "Body Armours" "Helmets" "Gloves" "Boots" "Shields"
    LinkedSockets >= 4
    Rarity <= Rare
    SetFontSize 39
    SetTextColor 174 174 178 255
    SetBorderColor 160 160 165 255
    SetBackgroundColor 16 16 22 255
    PlayAlertSound 2 300
    MinimapIcon 1 Grey Circle


#==[128002]- Campaign Armour -3-Link Early (Campaign) 过渡护甲 - Class Condition==
Show
    Class "Body Armours" "Helmets" "Gloves" "Boots"
    LinkedSockets >= 3
    AreaLevel <= 40
    Rarity <= Rare
    SetFontSize 36
    SetTextColor 188 188 192 255
    SetBorderColor 88 88 91 255
    SetBackgroundColor 10 10 13 255


#==[128003]- Campaign Armour -Hide (Post-Campaign) 过渡护甲 - Class Condition==
Hide
    Class "Body Armours" "Helmets" "Gloves" "Boots"
    AreaLevel >= 68
    SetFontSize 18
    SetTextColor 90 90 100 170
    SetBorderColor 45 45 52 120
    SetBackgroundColor 0 0 0 0


#==[129000]-过渡 _campaign - 色卡配方物品 Chromatic Recipe Items==

#==[130000]-过渡 _campaign - 过渡药剂 Campaign Flasks==

#==[130001]- Campaign Flasks -Quality Flasks (Campaign) 过渡药剂 - Class Condition==
