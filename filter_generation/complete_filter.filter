#==[15000]-过渡 _campaign - 连接突显 Links Highlight==

#==[15001]- 连接装备 -四连（至第五章） 连接突显 - Class Condition==
Show
    Class == "Bows" "Claws" "Daggers" "One Hand Axes" "One Hand Maces" "One Hand Swords" "Thrusting One Hand Swords" "Quivers" "Rune Daggers" "Sceptres" "Staves" "Two Hand Axes" "Two Hand Maces" "Two Hand Swords" "Wands" "Warstaves" "Body Armours" "Boots" "Gloves" "Helmets" "Shields"
    LinkedSockets >= 4
    Rarity <= Rare
    AreaLevel <= 45
    ItemLevel <= 50
    SetFontSize 40
    SetBorderColor 74 230 58 255
    SetBackgroundColor 215 215 200 210


#==[15002]- 连接装备 -三连（至第三章） 连接突显 - Class Condition==
Show
    Class == "Bows" "Claws" "Daggers" "One Hand Axes" "One Hand Maces" "One Hand Swords" "Thrusting One Hand Swords" "Quivers" "Rune Daggers" "Sceptres" "Staves" "Two Hand Axes" "Two Hand Maces" "Two Hand Swords" "Wands" "Warstaves" "Body Armours" "Boots" "Gloves" "Helmets" "Shields"
    LinkedSockets >= 3
    Rarity <= Rare
    AreaLevel <= 33
    ItemLevel <= 38
    SetFontSize 40
    SetBorderColor 74 230 58 255
    SetBackgroundColor 215 215 200 210


